      <!-- Левая колонка: контакты -->
      <div class="space-y-6 sm:space-y-8 lg:col-span-2">
        <!-- Телефоны -->
        <div class="bg-white/5 backdrop-blur-md border border-white/5 rounded-lg sm:rounded-2xl p-6 sm:p-8 hover:border-blue-400/40 hover:bg-white/10 transition duration-300 animate-fade-in delay-1">
