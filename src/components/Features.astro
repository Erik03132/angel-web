          <div class="space-y-3 sm:space-y-4">
            <a href="tel:+79183500225" class="flex items-center gap-3 p-3 sm:p-4 rounded-lg bg-white/5 hover:bg-white/10 transition group text-sm sm:text-base">
              <span class="text-cyan-400 font-bold">+7 (918) 350-02-25</span>
              <Icon name="mdi:open-in-new" class="w-4 sm:w-5 h-4 sm:h-5 text-blue-300/60 group-hover:text-blue-300 transition flex-shrink-0" />
