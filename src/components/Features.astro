          <h3 class="text-xl sm:text-2xl font-bold text-white mb-4 sm:mb-6 flex items-center gap-3">
            <Icon name="mdi:email" class="w-6 sm:w-7 h-6 sm:h-7 text-cyan-400 flex-shrink-0" />
            Email
