          <a href="mailto:VezemCip@yandex.com" class="flex items-center gap-3 p-3 sm:p-4 rounded-lg bg-white/5 hover:bg-white/10 transition group text-sm sm:text-base">
            <span class="text-cyan-400 font-bold break-all">VezemCip@yandex.com</span>
