---
/* Чат-виджет Анжелочки — AI-консультант на сайте */
---

<!-- Кнопка открытия чата -->
<button
  id="chat-toggle"
  class="fixed bottom-6 right-6 z-[60] w-16 h-16 rounded-full shadow-2xl flex items-center justify-center transition-all duration-300 hover:scale-110 group"
  style="background: linear-gradient(135deg, #06b6d4 0%, #3b82f6 50%, #8b5cf6 100%);"
  aria-label="Написать Анжелочке"
>
  <!-- Иконка чата -->
  <svg id="chat-icon-open" class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
  </svg>
  <!-- Иконка закрытия -->
  <svg id="chat-icon-close" class="w-7 h-7 text-white hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
  </svg>
  <!-- Пульсация -->
  <span class="absolute inset-0 rounded-full animate-ping opacity-30" style="background: linear-gradient(135deg, #06b6d4, #8b5cf6);"></span>
  <!-- Бейдж -->
  <span id="chat-badge" class="absolute -top-1 -right-1 w-5 h-5 bg-red-500 text-white text-[10px] font-bold rounded-full flex items-center justify-center shadow-lg">1</span>
</button>

<!-- Окно чата -->
<div
  id="chat-window"
  class="fixed bottom-24 right-6 z-[60] w-[380px] max-h-[580px] rounded-2xl shadow-2xl border border-white/10 overflow-hidden flex flex-col transition-all duration-300 scale-0 opacity-0 origin-bottom-right"
  style="background: linear-gradient(180deg, #0f172a 0%, #1e293b 100%);"
>
  <!-- Шапка -->
  <div class="flex items-center gap-3 px-5 py-4 border-b border-white/10" style="background: linear-gradient(135deg, rgba(6,182,212,0.15), rgba(139,92,246,0.15));">
    <div class="relative">
      <div class="w-10 h-10 rounded-full bg-gradient-to-br from-cyan-400 to-blue-500 flex items-center justify-center text-lg font-bold text-white shadow-lg">
        🐣
      </div>
      <span class="absolute bottom-0 right-0 w-3 h-3 bg-emerald-400 rounded-full border-2 border-slate-900"></span>
    </div>
    <div class="flex-1">
      <h3 class="text-white font-bold text-sm">Анжелочка</h3>
      <p class="text-cyan-300/70 text-xs">AI-менеджер • онлайн</p>
    </div>
    <button onclick="toggleChat()" class="text-white/50 hover:text-white transition p-1">
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
      </svg>
    </button>
  </div>

  <!-- Сообщения -->
  <div id="chat-messages" class="flex-1 overflow-y-auto px-4 py-4 space-y-3 min-h-[300px] max-h-[380px]">
    <!-- Приветственное сообщение -->
    <div class="flex items-start gap-2">
      <div class="w-7 h-7 rounded-full bg-gradient-to-br from-cyan-400 to-blue-500 flex items-center justify-center text-xs flex-shrink-0 mt-1 shadow">🐣</div>
      <div class="bg-white/10 rounded-2xl rounded-tl-sm px-4 py-2.5 max-w-[85%]">
        <p class="text-sm text-blue-100/90 leading-relaxed">Здравствуйте! Я <strong class="text-cyan-300">Анжелочка</strong>, менеджер Азовского Инкубатора 🐣<br><br>Помогу с выбором птицы, расскажу про цены и доставку. Что Вас интересует?</p>
      </div>
    </div>

    <!-- Быстрые кнопки -->
    <div id="quick-buttons" class="flex flex-wrap gap-2 pl-9">
      <button onclick="sendQuickMessage('Какие бройлеры есть?')" class="px-3 py-1.5 text-xs rounded-full border border-cyan-500/30 text-cyan-300 hover:bg-cyan-500/20 transition">🐔 Бройлеры</button>
      <button onclick="sendQuickMessage('Какие есть несушки?')" class="px-3 py-1.5 text-xs rounded-full border border-cyan-500/30 text-cyan-300 hover:bg-cyan-500/20 transition">🥚 Несушки</button>
      <button onclick="sendQuickMessage('Расскажите про уток')" class="px-3 py-1.5 text-xs rounded-full border border-cyan-500/30 text-cyan-300 hover:bg-cyan-500/20 transition">🦆 Утки</button>
      <button onclick="sendQuickMessage('Какие цены?')" class="px-3 py-1.5 text-xs rounded-full border border-cyan-500/30 text-cyan-300 hover:bg-cyan-500/20 transition">💰 Цены</button>
      <button onclick="sendQuickMessage('Как заказать?')" class="px-3 py-1.5 text-xs rounded-full border border-cyan-500/30 text-cyan-300 hover:bg-cyan-500/20 transition">📦 Заказ</button>
    </div>
  </div>

  <!-- Поле ввода -->
  <div class="px-4 py-3 border-t border-white/10 bg-slate-900/50">
    <form id="chat-form" class="flex items-center gap-2">
      <input
        id="chat-input"
        type="text"
        placeholder="Напишите сообщение..."
        autocomplete="off"
        class="flex-1 px-4 py-2.5 rounded-xl bg-white/10 border border-white/10 text-white text-sm placeholder-white/40 focus:outline-none focus:border-cyan-400/50 transition"
      />
      <button
        type="submit"
        id="chat-send-btn"
        class="w-10 h-10 rounded-xl flex items-center justify-center transition-all hover:scale-110 disabled:opacity-40 disabled:hover:scale-100"
        style="background: linear-gradient(135deg, #06b6d4, #3b82f6);"
      >
        <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
        </svg>
      </button>
    </form>
  </div>
</div>


<script>
  // === Состояние чата ===
  let chatOpen = false;
  let sessionId = localStorage.getItem('angelochka_session') || '';
  let isTyping = false;

  // API URL бэкенда Анжелочки
  // Берется из .env (PUBLIC_API_URL) или использует локальный 8002
  const API_URL = "PUBLIC_API_URL" in import.meta.env
    ? import.meta.env.PUBLIC_API_URL
    : (window.location.hostname === 'localhost' ? 'http://localhost:8002' : 'https://angelochka-api.example.com');

  // === Переключение окна чата ===
  window.toggleChat = function() {
    const win = document.getElementById('chat-window');
    const iconOpen = document.getElementById('chat-icon-open');
    const iconClose = document.getElementById('chat-icon-close');
    const badge = document.getElementById('chat-badge');

    chatOpen = !chatOpen;

    if (chatOpen) {
      win?.classList.remove('scale-0', 'opacity-0');
      win?.classList.add('scale-100', 'opacity-100');
      iconOpen?.classList.add('hidden');
      iconClose?.classList.remove('hidden');
      badge?.classList.add('hidden');
      document.getElementById('chat-input')?.focus();
    } else {
      win?.classList.remove('scale-100', 'opacity-100');
      win?.classList.add('scale-0', 'opacity-0');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
    }
  };

  // Кнопка переключения
  document.getElementById('chat-toggle')?.addEventListener('click', () => window.toggleChat());

  // === Отправка быстрого сообщения ===
  window.sendQuickMessage = function(text) {
    const input = document.getElementById('chat-input');
    if (input) {
      (input as HTMLInputElement).value = text;
    }
    // Скрываем быстрые кнопки
    const qb = document.getElementById('quick-buttons');
    if (qb) qb.style.display = 'none';
    sendMessage(text);
  };

  // === Отправка сообщения ===
  async function sendMessage(text: string) {
    if (!text.trim() || isTyping) return;
    isTyping = true;

    const input = document.getElementById('chat-input') as HTMLInputElement;
    const sendBtn = document.getElementById('chat-send-btn') as HTMLButtonElement;
    if (input) input.value = '';
    if (sendBtn) sendBtn.disabled = true;

    // Добавляем сообщение пользователя
    appendMessage('user', text);

    // Показываем индикатор набора
    const typingId = showTypingIndicator();

    try {
      const response = await fetch(`${API_URL}/api/chat`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: text, session_id: sessionId })
      });

      const data = await response.json();

      // Сохраняем session_id
      if (data.session_id) {
        sessionId = data.session_id;
        localStorage.setItem('angelochka_session', sessionId);
      }

      // Убираем индикатор и показываем ответ
      removeTypingIndicator(typingId);
      appendMessage('bot', data.response || 'Прости, не смогла ответить. Попробуй ещё раз!');

      // Проверяем, содержит ли ответ номер телефона / готовность к заказу
      checkForLeadIntent(text, data.response);

    } catch (error) {
      removeTypingIndicator(typingId);
      appendMessage('bot', '⚠️ Не удалось связаться с сервером. Проверьте подключение и попробуйте ещё раз.');
      console.error('Chat error:', error);
    } finally {
      isTyping = false;
      if (sendBtn) sendBtn.disabled = false;
      if (input) input.focus();
    }
  }

  // === Добавление сообщения в чат ===
  function appendMessage(sender: 'user' | 'bot', text: string) {
    const container = document.getElementById('chat-messages');
    if (!container) return;

    const div = document.createElement('div');

    if (sender === 'user') {
      div.className = 'flex justify-end';
      div.innerHTML = `
        <div class="bg-gradient-to-r from-cyan-500/20 to-blue-500/20 border border-cyan-500/20 rounded-2xl rounded-tr-sm px-4 py-2.5 max-w-[85%]">
          <p class="text-sm text-white leading-relaxed">${escapeHtml(text)}</p>
        </div>
      `;
    } else {
      // Форматируем ответ бота (markdown-like)
      const formatted = formatBotResponse(text);
      div.className = 'flex items-start gap-2';
      div.innerHTML = `
        <div class="w-7 h-7 rounded-full bg-gradient-to-br from-cyan-400 to-blue-500 flex items-center justify-center text-xs flex-shrink-0 mt-1 shadow">🐣</div>
        <div class="bg-white/10 rounded-2xl rounded-tl-sm px-4 py-2.5 max-w-[85%]">
          <div class="text-sm text-blue-100/90 leading-relaxed">${formatted}</div>
        </div>
      `;
    }

    container.appendChild(div);
    container.scrollTop = container.scrollHeight;
  }

  // === Форматирование ответа бота ===
  function formatBotResponse(text: string): string {
    return text
      .replace(/\*\*(.*?)\*\*/g, '<strong class="text-cyan-300">$1</strong>')
      .replace(/\*(.*?)\*/g, '<em>$1</em>')
      .replace(/\n/g, '<br>')
      .replace(/([👉💡🐣🐔🦆🥚📦✅⚡🔥❗])/g, '<span class="text-base">$1</span>');
  }

  // === Индикатор набора ===
  function showTypingIndicator(): string {
    const container = document.getElementById('chat-messages');
    if (!container) return '';

    const id = 'typing-' + Date.now();
    const div = document.createElement('div');
    div.id = id;
    div.className = 'flex items-start gap-2';
    div.innerHTML = `
      <div class="w-7 h-7 rounded-full bg-gradient-to-br from-cyan-400 to-blue-500 flex items-center justify-center text-xs flex-shrink-0 mt-1 shadow">🐣</div>
      <div class="bg-white/10 rounded-2xl rounded-tl-sm px-4 py-3">
        <div class="flex gap-1.5">
          <span class="w-2 h-2 bg-cyan-400/60 rounded-full animate-bounce" style="animation-delay: 0ms;"></span>
          <span class="w-2 h-2 bg-cyan-400/60 rounded-full animate-bounce" style="animation-delay: 150ms;"></span>
          <span class="w-2 h-2 bg-cyan-400/60 rounded-full animate-bounce" style="animation-delay: 300ms;"></span>
        </div>
      </div>
    `;
    container.appendChild(div);
    container.scrollTop = container.scrollHeight;
    return id;
  }

  function removeTypingIndicator(id: string) {
    const el = document.getElementById(id);
    if (el) el.remove();
  }

  // === Escaping HTML ===
  function escapeHtml(text: string): string {
    const map: Record<string, string> = { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;' };
    return text.replace(/[&<>"']/g, m => map[m]);
  }

  // === Проверка намерения оставить заявку ===
  function checkForLeadIntent(userMsg: string, botResponse: string) {
    const phoneRegex = /(\+?[78][\s\-]?\(?\d{3}\)?[\s\-]?\d{3}[\s\-]?\d{2}[\s\-]?\d{2})/;
    const phoneMatch = userMsg.match(phoneRegex);

    if (phoneMatch) {
      // Клиент оставил телефон — создаём лид!
      createLead(phoneMatch[1], userMsg);
    }
  }

  // === Создание лида в Битрикс24 ===
  async function createLead(phone: string, context: string) {
    try {
      const response = await fetch(`${API_URL}/api/lead`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: 'Посетитель сайта',
          phone: phone,
          comment: `Заявка из чата на сайте.\n\nКонтекст разговора: ${context}`
        })
      });

      if (response.ok) {
        console.log('✅ Лид создан в Битрикс24!');
      }
    } catch (error) {
      console.error('Lead creation error:', error);
    }
  }

  // === Обработка формы ===
  document.getElementById('chat-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const input = document.getElementById('chat-input') as HTMLInputElement;
    if (input?.value.trim()) {
      // Скрываем быстрые кнопки при первом сообщении
      const qb = document.getElementById('quick-buttons');
      if (qb) qb.style.display = 'none';
      sendMessage(input.value.trim());
    }
  });
</script>


<style>
  /* Анимация для мобильных */
  @media (max-width: 640px) {
    #chat-window {
      width: calc(100vw - 2rem) !important;
      max-height: calc(100vh - 8rem) !important;
      bottom: 5rem !important;
      right: 1rem !important;
    }
  }
</style>
