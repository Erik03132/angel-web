  // Отрисовка товаров
  function renderProducts() {
    const grid = document.getElementById('products-grid');
    grid.innerHTML = '';

    const filtered = selectedCategory === 'all' 
      ? productsData 
      : productsData.filter(p => p.category === selectedCategory);

    filtered.forEach(product => {
      const card = document.createElement('div');
      card.className = 'product-card group bg-gradient-to-br from-white/10 to-white/5 backdrop-blur-md border border-white/20 rounded-xl overflow-hidden hover:border-cyan-400/50 hover:from-white/15 transition duration-300 cursor-pointer transform hover:scale-105 hover:shadow-2xl';
      card.innerHTML = `
        <div class="${product.image ? 'bg-white/10' : `bg-gradient-to-r ${product.color}`} flex items-center justify-center group-hover:scale-110 transition duration-300 aspect-square relative">
          ${product.image ? `<div class="absolute inset-0 bg-gradient-to-br ${product.color} opacity-10 blur-2xl"></div><img src="${product.image}" alt="${product.name}" class="w-full h-full object-contain p-2 relative z-10">` : `<div class="text-5xl sm:text-6xl">${product.icon}</div>`}
        </div>
        <div class="p-3 sm:p-6">
          <h3 class="text-base sm:text-xl font-bold text-white mb-1 sm:mb-2">${product.name}</h3>
          <p class="text-xs sm:text-sm text-blue-100/70 line-clamp-2 mb-3 sm:mb-4">${product.description}</p>
          
          <div class="flex items-center justify-between">
            <div class="text-xs sm:text-sm font-semibold text-cyan-300">
              ${typeof product.pricing === 'string' ? product.pricing : `От ${product.pricing[product.pricing.length - 1].price} ₽`}
            </div>
            <svg class="w-4 h-4 sm:w-5 sm:h-5 text-cyan-400 group-hover:translate-x-1 transition" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7"/></svg>
          </div>
        </div>
      `;
      
      card.addEventListener('click', () => openModal(product));
      grid.appendChild(card);
    });
  }

  // Настройка кнопок категорий
  function setupCategoryButtons() {
    document.querySelectorAll('.category-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.category-btn').forEach(b => {
          b.classList.remove('active');
          b.classList.add('bg-white/5', 'text-blue-200', 'border', 'border-white/10');
          b.classList.remove('bg-gradient-to-r', 'from-cyan-500', 'to-emerald-500', 'text-white', 'border-cyan-400/50');
        });
        
        btn.classList.add('active');
        btn.classList.add('bg-gradient-to-r', 'from-cyan-500', 'to-emerald-500', 'text-white', 'border-cyan-400/50');
        btn.classList.remove('bg-white/5', 'text-blue-200', 'border', 'border-white/10');
        
        selectedCategory = btn.dataset.category;
        renderProducts();
      });
    });
    
    // Стиль активной кнопки
    document.querySelector('.category-btn.active').classList.add('bg-gradient-to-r', 'from-cyan-500', 'to-emerald-500', 'text-white', 'border-cyan-400/50');
    document.querySelector('.category-btn.active').classList.remove('bg-white/5', 'text-blue-200', 'border', 'border-white/10');
  }

  // Открыть модаль
  function openModal(product) {
    currentProduct = product;
    
    document.getElementById('modal-title').textContent = product.name;
    document.getElementById('modal-description').textContent = product.description;
    document.getElementById('quantity-input').value = 20;
    
    // Отображение картинки если есть
    const modalImage = document.getElementById('modal-image');
    if (product.image) {
      modalImage.src = product.image;
      modalImage.alt = product.name;
      modalImage.classList.remove('hidden');
    } else {
      modalImage.classList.add('hidden');
    }
    
    // Таблица цен
    const pricingTable = document.getElementById('pricing-table');
    const pricingSection = document.getElementById('pricing-section');
    
    if (typeof product.pricing === 'string') {
      pricingTable.innerHTML = `
        <div class="bg-white/10 border border-white/10 rounded-lg p-4 text-center">
          <p class="text-blue-100/90 font-semibold">${product.pricing}</p>
          <p class="text-xs text-blue-100/60 mt-2">Уточните цену у менеджера</p>
        </div>
      `;
      pricingSection.style.display = product.pricing === 'По запросу' ? 'block' : 'none';
    } else {
      pricingTable.innerHTML = product.pricing.map(tier => `
        <div class="flex items-center justify-between bg-white/5 border border-white/10 rounded-lg p-3">
          <span class="text-blue-100/80">${tier.label}</span>
          <span class="text-cyan-300 font-bold text-lg">${tier.price} ₽/шт</span>
        </div>
      `).join('');
      
      if (product.hasCustomDiscount) {
        pricingTable.innerHTML += `
          <div class="bg-emerald-500/20 border border-emerald-500/50 rounded-lg p-3 mt-2">
            <p class="text-sm text-emerald-300 font-semibold">💎 При заказе от 1000 штук</p>
            <p class="text-xs text-emerald-300/80 mt-1">Получите индивидуальную скидку через менеджера!</p>
          </div>
        `;
      }
    }
    
    updatePriceDisplay();
    document.getElementById('product-modal').classList.remove('hidden');
  }

  // Закрыть модаль
  function closeModal() {
    document.getElementById('product-modal').classList.add('hidden');
    currentProduct = null;
  }

  // Сделать функции доступными глобально
  window.openModal = openModal;
  window.closeModal = closeModal;

  // Обновить отображение цены
  function updatePriceDisplay() {
    if (!currentProduct || typeof currentProduct.pricing === 'string') {
      document.getElementById('price-display').textContent = 'Уточните цену у менеджера';
      return;
    }

    const qty = parseInt(document.getElementById('quantity-input').value);
    const tier = [...currentProduct.pricing].reverse().find(t => qty >= t.min);
    
    if (tier) {
      const total = qty * tier.price;
      document.getElementById('price-display').textContent = `${tier.price} ₽/шт × ${qty} шт = ${total.toLocaleString('ru-RU')} ₽`;
    }
  }

  // Увеличить количество
  window.increaseQty = function() {
    const input = document.getElementById('quantity-input');
    input.value = Math.min(parseInt(input.value) + 10, 10000);
    updatePriceDisplay();
  }

  // Уменьшить количество
  window.decreaseQty = function() {
    const input = document.getElementById('quantity-input');
    input.value = Math.max(parseInt(input.value) - 10, 1);
    updatePriceDisplay();
  }

  // Слушатель изменения количества
  document.addEventListener('input', (e) => {
    if (e.target.id === 'quantity-input') {
      updatePriceDisplay();
    }
  });

  // Добавить в корзину из модали
  window.addToCartFromModal = function() {
    if (!currentProduct) return;

    const qty = parseInt(document.getElementById('quantity-input').value);
    
    let price = 0;
    let requiresQuote = false;

    if (typeof currentProduct.pricing === 'string') {
      // Товар требует уточнения
      requiresQuote = true;
      price = 0; // Цена 0 для товаров по запросу
    } else {
      const tier = [...currentProduct.pricing].reverse().find(t => qty >= t.min);
      price = tier ? tier.price : currentProduct.pricing[currentProduct.pricing.length - 1].price;
    }

    // Вызываем глобальную функцию из FloatingCart
    if (window.addToCart) {
      window.addToCart(currentProduct.id, currentProduct.name, price, qty, requiresQuote);
      // Уведомление теперь показывается внутри addToCart, не нужно дублировать
      closeModal();
    }
  };

  // Инициализация при загрузке
  init();

  // Закрыть модаль при клике вне её окна
  document.getElementById('product-modal').addEventListener('click', function(e) {
    if (e.target === this) {
      closeModal();
    }
  });
</script>

<style>
  .category-btn {
    background-color: rgba(255, 255, 255, 0.05);
    color: rgb(191, 219, 254);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .category-btn.active {
    background: linear-gradient(to right, rgb(34, 197, 94), rgb(16, 185, 129));
    color: white;
    border-color: rgba(34, 211, 238, 0.5);
  }
</style>
