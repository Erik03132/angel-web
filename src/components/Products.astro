---
import { Icon } from 'astro-icon/components';
---

<section id="products" class="py-20 lg:py-32 relative">

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-16">
      <div class="inline-block mb-4 px-4 py-2 rounded-full bg-blue-500/20 border border-blue-400/50 backdrop-blur-md">
        <span class="text-sm font-semibold bg-gradient-to-r from-blue-300 to-cyan-300 bg-clip-text text-transparent">КАТАЛОГ ПРОДУКЦИИ</span>
      </div>
      <h2 class="text-4xl md:text-6xl font-black text-white mb-6">
        Наш <span class="bg-gradient-to-r from-blue-400 via-cyan-300 to-emerald-400 bg-clip-text text-transparent">ассортимент</span>
      </h2>
      <p class="text-xl text-blue-100/90 max-w-2xl mx-auto">
        Здоровый молодняк птицы с гарантией выживаемости и ветеринарным контролем
      </p>
    </div>

    <!-- Навигация по категориям (скрыта до раскрытия каталога) -->
    <div id="category-nav" class="flex flex-wrap gap-3 justify-center mb-12 hidden">
      <button class="category-btn active px-6 py-2 rounded-full font-semibold text-sm transition duration-300" data-category="all">
        Все
      </button>
      <button class="category-btn px-6 py-2 rounded-full font-semibold text-sm transition duration-300" data-category="broilers">
        Бройлеры
      </button>
      <button class="category-btn px-6 py-2 rounded-full font-semibold text-sm transition duration-300" data-category="layers">
        Несушки
      </button>
      <button class="category-btn px-6 py-2 rounded-full font-semibold text-sm transition duration-300" data-category="dual">
        Мясояичные
      </button>
      <button class="category-btn px-6 py-2 rounded-full font-semibold text-sm transition duration-300" data-category="ducks">
        Утята
      </button>
      <button class="category-btn px-6 py-2 rounded-full font-semibold text-sm transition duration-300" data-category="geese">
        Гусята
      </button>
      <button class="category-btn px-6 py-2 rounded-full font-semibold text-sm transition duration-300" data-category="turkeys">
        Индюшата
      </button>
    </div>

    <!-- Сетка товаров -->
    <div id="products-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6 mb-8">
      <!-- Карточки будут добавлены через JavaScript -->
    </div>

    <!-- Кнопка "Смотреть весь каталог" -->
    <div id="expand-catalog-wrap" class="text-center mb-12">
      <button id="expand-catalog-btn" class="group inline-flex items-center gap-3 px-8 py-4 rounded-2xl font-bold text-lg text-white overflow-hidden relative shadow-xl hover:shadow-cyan-500/30 transition-all duration-300 hover:scale-105">
        <div class="absolute inset-0 bg-gradient-to-r from-cyan-600 via-blue-600 to-emerald-600"></div>
        <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition duration-500 bg-gradient-to-r from-cyan-500 via-blue-500 to-emerald-500"></div>
        <span class="relative z-10">Смотреть весь каталог</span>
        <svg class="relative z-10 w-6 h-6 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7"/></svg>
        <span class="relative z-10 bg-white/20 text-white text-sm px-3 py-1 rounded-full" id="total-count-badge"></span>
      </button>
    </div>
  </div>

  <!-- Модаль с деталями -->
  <div id="product-modal" class="fixed inset-0 bg-black/80 backdrop-blur-md z-50 hidden flex items-center justify-center p-2 sm:p-4">
    <div class="bg-gradient-to-b from-slate-900 to-blue-950 rounded-lg sm:rounded-2xl border border-white/10 max-w-lg sm:max-w-2xl w-full shadow-2xl max-h-[95vh] sm:max-h-[90vh] overflow-y-auto flex flex-col">
      <div class="flex items-center justify-between p-3 sm:p-4 border-b border-white/10 flex-shrink-0">
        <h3 id="modal-title" class="text-lg sm:text-2xl font-bold text-white"></h3>
        <button onclick="closeModal()" class="text-white/60 hover:text-white transition">
          <Icon name="mdi:close" class="w-5 h-5 sm:w-6 sm:h-6" />
        </button>
      </div>

      <div class="p-3 sm:p-5 overflow-y-auto flex-1">
        <div class="space-y-4 sm:space-y-5">
          <!-- Картинка товара с блюром -->
          <div class="relative mb-4">
            <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-blue-600/20 rounded-xl sm:rounded-2xl blur-2xl -z-10"></div>
            <img id="modal-image" src="" alt="" class="w-4/5 h-auto rounded-xl sm:rounded-2xl mx-auto shadow-lg sm:shadow-2xl shadow-blue-500/30 hidden">
          </div>
          
          <!-- Описание -->
          <div>
            <h4 class="text-sm sm:text-lg font-semibold text-cyan-300 mb-2">О породе</h4>
            <p id="modal-description" class="text-xs sm:text-sm text-blue-100/90 leading-relaxed"></p>
          </div>

          <!-- Таблица цен -->
          <div id="pricing-section">
            <h4 class="text-sm sm:text-lg font-semibold text-cyan-300 mb-2">Прайс-лист</h4>
            <div id="pricing-table" class="space-y-1 sm:space-y-2"></div>
          </div>

          <!-- Выбор количества -->
          <div class="bg-white/5 backdrop-blur-md border border-white/10 rounded-lg sm:rounded-xl p-3 sm:p-4">
            <label class="block text-xs sm:text-sm font-semibold text-cyan-300 mb-2">Выберите количество</label>
            <div class="flex items-center gap-2 sm:gap-4">
              <button onclick="decreaseQty()" class="px-2 sm:px-4 py-1 sm:py-2 rounded-lg bg-blue-500/20 hover:bg-blue-500/40 text-white transition">
                <Icon name="mdi:minus" class="w-4 h-4 sm:w-5 sm:h-5" />
              </button>
              <input id="quantity-input" type="number" value="20" min="1" max="10000" class="flex-1 px-2 sm:px-4 py-1 sm:py-2 rounded-lg bg-white/10 border border-white/20 text-white text-center font-semibold text-xs sm:text-sm focus:outline-none focus:border-cyan-400/50">
              <button onclick="increaseQty()" class="px-2 sm:px-4 py-1 sm:py-2 rounded-lg bg-blue-500/20 hover:bg-blue-500/40 text-white transition">
                <Icon name="mdi:plus" class="w-4 h-4 sm:w-5 sm:h-5" />
              </button>
            </div>
            <p id="price-display" class="text-cyan-300 font-bold text-sm sm:text-lg mt-2 sm:mt-3 text-center"></p>
          </div>
        </div>
      </div>

      <!-- Кнопка добавления в корзину -->
      <div class="p-6 border-t border-white/10 flex gap-3 flex-shrink-0">
        <button onclick="closeModal()" class="flex-1 px-6 py-3 rounded-xl bg-white/10 hover:bg-white/20 text-white font-semibold transition">
          Закрыть
        </button>
        <button id="add-to-cart-btn" onclick="addToCartFromModal()" class="flex-1 px-6 py-3 rounded-xl font-bold text-white overflow-hidden relative shadow-xl">
          <div class="absolute inset-0 bg-gradient-to-r from-emerald-600 via-cyan-500 to-blue-600 transition"></div>
          <div class="absolute inset-0 opacity-0 hover:opacity-100 transition duration-300 bg-gradient-to-r from-emerald-500 via-cyan-400 to-blue-500 blur-xl"></div>
          <span class="relative z-10 flex items-center justify-center gap-2">
            <Icon name="mdi:cart-plus" class="w-5 h-5" />
            <span>В корзину</span>
          </span>
        </button>
      </div>
    </div>
  </div>
</section>

