      description: 'Высокопродуктивная порода с превосходным пухом и мягким мясом. Одна из самых красивых пород белого гуся. Очень миролюбивые.',
      image: '',
      pricing: 'От 420 ₽',
      icon: '🦢',
      color: 'from-blue-200 to-blue-400'
    },
    {
      id: 'goose-italian',
      name: 'Гусята Итальянские',
      category: 'geese',
      description: 'Идеальны для небольших ферм. Высокая яйценоскость гусынь и нежное мясо. Часто используются для получения деликатесной печени.',
      image: '',
      pricing: 'От 400 ₽',
      icon: '🦢',
      color: 'from-emerald-300 to-emerald-500'
    },
    {
      id: 'goose-governor',
      name: 'Гусята Губернаторские',
      category: 'geese',
      description: 'Современный кросс с высочайшей выживаемостью молодняка. Оперение белое. Вкусное сочное мясо.',
      image: '',
      pricing: 'От 400 ₽',
      icon: '🦢',
      color: 'from-slate-400 to-slate-600'
    },

    // ИНДЮШАТА
    {
      id: 'hybrid-converter',
      name: 'Хайбрид Конвертер (Белые широкогрудые)',
      category: 'turkeys',
      description: 'Тяжелый кросс из Канады ("Индюки-быки"). Выдающаяся мясистость: индюки за полгода могут достигать 25-30 кг!',
      image: '/Konverter.png',
      pricing: 'От 500 ₽',
      icon: '🦃',
      color: 'from-red-500 to-orange-600'
    },
    {
      id: 'big-6',
      name: 'Биг-6',
      category: 'turkeys',
      description: 'Суточные индюшата тяжелого английского кросса Биг-6. Классика мясного индюководства, огромная грудка и мощный костяк.',
      image: '/Big6.png',
      pricing: 'От 500 ₽',
      icon: '🦃',
      color: 'from-orange-600 to-amber-600'
    },
    {
      id: 'grade-maker',
      name: 'Грейд Мейкер (Праздничная индейка)',
      category: 'turkeys',
      description: 'Средне-тяжелый кросс (Франция). Очень привлекательный внешний вид тушки "товарного" размера (до 15-20 кг). Более устойчивы к инфекциям.',
      image: '/GrayMaker.png',
      pricing: 'От 450 ₽',
      icon: '🦃',
      color: 'from-amber-600 to-yellow-600'
    },
    {
      id: 'bronze-708',
      name: 'Бронза-708',
      category: 'turkeys',
      description: 'Широкогрудый кросс с невероятно красивым бронзовым оперением. Тяжеловес среди цветных индеек.',
      image: 'Bronze.png',
      pricing: 'От 550 ₽',
      icon: '🦃',
      color: 'from-yellow-600 to-orange-700'
    },
    {
      id: 'victoria',
      name: 'Виктория (Крестовая)',
      category: 'turkeys',
      description: 'Отечественный кросс белой индейки. Отлично приспособлен к нашим перепадам температур, неприхотлив к кормам.',
      image: '',
      pricing: 'От 400 ₽',
      icon: '🦃',
      color: 'from-slate-400 to-slate-600'
    }
  ];

  let currentProduct = null;
  let selectedCategory = 'all';
  let catalogExpanded = false;

  // Три топ-породы на главной
  const featuredIds = ['ross308', 'loman-brown', 'hybrid-converter'];

  // Категория → красивая SVG-иконка
  const categoryIcons = {
    broilers: '<svg viewBox="0 0 64 64" class="w-16 h-16 sm:w-20 sm:h-20 opacity-60"><text x="50%" y="55%" text-anchor="middle" dominant-baseline="central" font-size="48">🐔</text></svg>',
    layers: '<svg viewBox="0 0 64 64" class="w-16 h-16 sm:w-20 sm:h-20 opacity-60"><text x="50%" y="55%" text-anchor="middle" dominant-baseline="central" font-size="48">🥚</text></svg>',
    dual: '<svg viewBox="0 0 64 64" class="w-16 h-16 sm:w-20 sm:h-20 opacity-60"><text x="50%" y="55%" text-anchor="middle" dominant-baseline="central" font-size="48">🐓</text></svg>',
    ducks: '<svg viewBox="0 0 64 64" class="w-16 h-16 sm:w-20 sm:h-20 opacity-60"><text x="50%" y="55%" text-anchor="middle" dominant-baseline="central" font-size="48">🦆</text></svg>',
    geese: '<svg viewBox="0 0 64 64" class="w-16 h-16 sm:w-20 sm:h-20 opacity-60"><text x="50%" y="55%" text-anchor="middle" dominant-baseline="central" font-size="48">🦢</text></svg>',
    turkeys: '<svg viewBox="0 0 64 64" class="w-16 h-16 sm:w-20 sm:h-20 opacity-60"><text x="50%" y="55%" text-anchor="middle" dominant-baseline="central" font-size="48">🦃</text></svg>'
  };

  // Инициализация
  function init() {
    document.getElementById('total-count-badge').textContent = productsData.length + ' пород';
    renderProducts();
    setupCategoryButtons();
    setupExpandButton();
  }

  // Кнопка раскрытия каталога
  function setupExpandButton() {
    const btn = document.getElementById('expand-catalog-btn');
    if (btn) {
      btn.addEventListener('click', () => {
        catalogExpanded = true;
        document.getElementById('category-nav').classList.remove('hidden');
        document.getElementById('expand-catalog-wrap').classList.add('hidden');
        // Переключаем сетку на 4 колонки для полного каталога
        const grid = document.getElementById('products-grid');
        grid.classList.remove('lg:grid-cols-3');
        grid.classList.add('lg:grid-cols-3', 'xl:grid-cols-4');
        renderProducts();
        // Плавный скролл к категориям
        document.getElementById('category-nav').scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    }
  }

  // Отрисовка товаров
  function renderProducts() {
    const grid = document.getElementById('products-grid');
    grid.innerHTML = '';

    let items;
    if (!catalogExpanded) {
      // Показываем только 3 топ-породы
      items = productsData.filter(p => featuredIds.includes(p.id));
    } else {
      items = selectedCategory === 'all'
        ? productsData
        : productsData.filter(p => p.category === selectedCategory);
    }

    items.forEach(product => {
      const card = document.createElement('div');
      card.className = 'product-card group bg-gradient-to-br from-white/10 to-white/5 backdrop-blur-md border border-white/20 rounded-xl overflow-hidden hover:border-cyan-400/50 hover:from-white/15 transition duration-300 cursor-pointer transform hover:scale-[1.03] hover:shadow-2xl hover:shadow-cyan-500/10';

      const hasImage = product.image && product.image.length > 0;
      const priceText = typeof product.pricing === 'string' ? product.pricing : `От ${product.pricing[product.pricing.length - 1].price} ₽`;

      // Красивая карточка: фото или стильный градиент
      const imageBlock = hasImage
        ? `<div class="bg-white/5 flex items-center justify-center aspect-square relative overflow-hidden">
             <div class="absolute inset-0 bg-gradient-to-br ${product.color} opacity-10 blur-2xl"></div>
             <img src="${product.image}" alt="${product.name}" class="w-full h-full object-contain p-3 relative z-10 group-hover:scale-110 transition duration-500">
           </div>`
        : `<div class="bg-gradient-to-br ${product.color} flex flex-col items-center justify-center aspect-square relative overflow-hidden">
             <div class="absolute inset-0 bg-black/20"></div>
             <div class="relative z-10">${categoryIcons[product.category] || ''}</div>
             <span class="relative z-10 text-white/90 font-bold text-sm mt-2 px-3 text-center leading-tight">${product.name}</span>
           </div>`;

      card.innerHTML = `
        ${imageBlock}
        <div class="p-3 sm:p-5">
          <h3 class="text-sm sm:text-lg font-bold text-white mb-1 sm:mb-2 leading-tight">${product.name}</h3>
          <p class="text-xs sm:text-sm text-blue-100/60 line-clamp-2 mb-3">${product.description}</p>
          <div class="flex items-center justify-between">
            <div class="text-xs sm:text-sm font-semibold text-cyan-300">${priceText}</div>
            <svg class="w-4 h-4 sm:w-5 sm:h-5 text-cyan-400 group-hover:translate-x-1 transition" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7"/></svg>
          </div>
        </div>
      `;

      card.addEventListener('click', () => openModal(product));
      grid.appendChild(card);
    });
  }

  // Настройка кнопок категорий
  function setupCategoryButtons() {
    document.querySelectorAll('.category-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.category-btn').forEach(b => {
          b.classList.remove('active');
          b.classList.add('bg-white/5', 'text-blue-200', 'border', 'border-white/10');
          b.classList.remove('bg-gradient-to-r', 'from-cyan-500', 'to-emerald-500', 'text-white', 'border-cyan-400/50');
        });
        
        btn.classList.add('active');
        btn.classList.add('bg-gradient-to-r', 'from-cyan-500', 'to-emerald-500', 'text-white', 'border-cyan-400/50');
        btn.classList.remove('bg-white/5', 'text-blue-200', 'border', 'border-white/10');
        
        selectedCategory = btn.dataset.category;
        renderProducts();
      });
    });
    
    // Стиль активной кнопки
    document.querySelector('.category-btn.active').classList.add('bg-gradient-to-r', 'from-cyan-500', 'to-emerald-500', 'text-white', 'border-cyan-400/50');
    document.querySelector('.category-btn.active').classList.remove('bg-white/5', 'text-blue-200', 'border', 'border-white/10');
  }

  // Открыть модаль
  function openModal(product) {
    currentProduct = product;
    
    document.getElementById('modal-title').textContent = product.name;
    document.getElementById('modal-description').textContent = product.description;
    document.getElementById('quantity-input').value = 20;
    
    // Отображение картинки если есть
    const modalImage = document.getElementById('modal-image');
    if (product.image) {
      modalImage.src = product.image;
      modalImage.alt = product.name;
      modalImage.classList.remove('hidden');
    } else {
      modalImage.classList.add('hidden');
    }
    
    // Таблица цен
    const pricingTable = document.getElementById('pricing-table');
    const pricingSection = document.getElementById('pricing-section');
    
    if (typeof product.pricing === 'string') {
      pricingTable.innerHTML = `
        <div class="bg-white/10 border border-white/10 rounded-lg p-4 text-center">
          <p class="text-blue-100/90 font-semibold">${product.pricing}</p>
          <p class="text-xs text-blue-100/60 mt-2">Уточните цену у менеджера</p>
        </div>
      `;
      pricingSection.style.display = product.pricing === 'По запросу' ? 'block' : 'none';
    } else {
      pricingTable.innerHTML = product.pricing.map(tier => `
        <div class="flex items-center justify-between bg-white/5 border border-white/10 rounded-lg p-3">
          <span class="text-blue-100/80">${tier.label}</span>
          <span class="text-cyan-300 font-bold text-lg">${tier.price} ₽/шт</span>
        </div>
      `).join('');
      
      if (product.hasCustomDiscount) {
        pricingTable.innerHTML += `
          <div class="bg-emerald-500/20 border border-emerald-500/50 rounded-lg p-3 mt-2">
            <p class="text-sm text-emerald-300 font-semibold">💎 При заказе от 1000 штук</p>
            <p class="text-xs text-emerald-300/80 mt-1">Получите индивидуальную скидку через менеджера!</p>
          </div>
        `;
      }
    }
    
    updatePriceDisplay();
    document.getElementById('product-modal').classList.remove('hidden');
  }

  // Закрыть модаль
  function closeModal() {
    document.getElementById('product-modal').classList.add('hidden');
    currentProduct = null;
  }

  // Сделать функции доступными глобально
  window.openModal = openModal;
  window.closeModal = closeModal;

  // Обновить отображение цены
  function updatePriceDisplay() {
    if (!currentProduct || typeof currentProduct.pricing === 'string') {
      document.getElementById('price-display').textContent = 'Уточните цену у менеджера';
      return;
    }

    const qty = parseInt(document.getElementById('quantity-input').value);
    const tier = [...currentProduct.pricing].reverse().find(t => qty >= t.min);
    
    if (tier) {
      const total = qty * tier.price;
      document.getElementById('price-display').textContent = `${tier.price} ₽/шт × ${qty} шт = ${total.toLocaleString('ru-RU')} ₽`;
    }
  }

  // Увеличить количество
  window.increaseQty = function() {
    const input = document.getElementById('quantity-input');
    input.value = Math.min(parseInt(input.value) + 10, 10000);
    updatePriceDisplay();
  }

  // Уменьшить количество
  window.decreaseQty = function() {
    const input = document.getElementById('quantity-input');
    input.value = Math.max(parseInt(input.value) - 10, 1);
    updatePriceDisplay();
  }

  // Слушатель изменения количества
  document.addEventListener('input', (e) => {
    if (e.target.id === 'quantity-input') {
      updatePriceDisplay();
    }
  });

  // Добавить в корзину из модали
  window.addToCartFromModal = function() {
    if (!currentProduct) return;

    const qty = parseInt(document.getElementById('quantity-input').value);
    
    let price = 0;
    let requiresQuote = false;

    if (typeof currentProduct.pricing === 'string') {
      // Товар требует уточнения
      requiresQuote = true;
      price = 0; // Цена 0 для товаров по запросу
    } else {
      const tier = [...currentProduct.pricing].reverse().find(t => qty >= t.min);
      price = tier ? tier.price : currentProduct.pricing[currentProduct.pricing.length - 1].price;
    }

    // Вызываем глобальную функцию из FloatingCart
    if (window.addToCart) {
      window.addToCart(currentProduct.id, currentProduct.name, price, qty, requiresQuote);
      // Уведомление теперь показывается внутри addToCart, не нужно дублировать
      closeModal();
    }
  };

  // Инициализация при загрузке
  init();

  // Закрыть модаль при клике вне её окна
  document.getElementById('product-modal').addEventListener('click', function(e) {
    if (e.target === this) {
      closeModal();
    }
  });
</script>

<style>
  .category-btn {
    background-color: rgba(255, 255, 255, 0.05);
    color: rgb(191, 219, 254);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .category-btn.active {
    background: linear-gradient(to right, rgb(34, 197, 94), rgb(16, 185, 129));
    color: white;
    border-color: rgba(34, 211, 238, 0.5);
  }
</style>
